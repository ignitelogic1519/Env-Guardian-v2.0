# Copy this to .env and fill in your values.
# In production (Render/host), set these in the dashboard's Environment tab —
# do NOT commit a real .env.

# ─── Server ───────────────────────────────────────────────────────────────────
PORT=3001
# Set NODE_ENV=production on the host. This enables SSL-by-default for the DB,
# combined access logs, and a startup check that rejects insecure secrets.
NODE_ENV=development

# ─── Database ─────────────────────────────────────────────────────────────────
# Local Postgres (no SSL):
DATABASE_URL=postgresql://postgres:YOUR_POSTGRES_PASSWORD@localhost:5432/neondb

# Neon Cloud / production (SSL auto-enabled for non-localhost hosts):
# DATABASE_URL=postgresql://neondb_owner:YOUR_PASSWORD@ep-blue-night-aoy31vjm-pooler.c-2.ap-southeast-1.aws.neon.tech/neondb?sslmode=require

# Optional DB tuning:
# PGSSL=true            # force SSL on/off (overrides auto-detection)
# DB_POOL_MAX=10        # max pooled connections

# ─── Security (MUST be changed for production) ────────────────────────────────
JWT_SECRET=envguardian_jwt_secret_change_in_production_2026
API_KEY=FoldedSteelSecret2026

# Admin (matches system_settings table)
ADMIN_PASSWORD=FoldedSteel2026

# ─── CORS ─────────────────────────────────────────────────────────────────────
# Comma-separated list of allowed dashboard origins (in addition to the built-in
# localhost + *.onrender.com / *.vercel.app / *.netlify.app defaults).
# Example:
# CORS_ORIGINS=https://dashboard.yourdomain.com,https://envguardian.vercel.app
